# Copy to .env (and set the same values in Vercel). Never commit .env.

# --- Client (Vite, exposed in the browser bundle — these are NOT secrets) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=tclife-771b9
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check (reCAPTCHA v3 site key from Firebase console → App Check).
# This is what restricts Firestore access to the real app once enforcement is on.
VITE_RECAPTCHA_SITE_KEY=
# Local dev only: leave unset to have the SDK log a debug token to register,
# or paste a token registered in the App Check console.
VITE_APPCHECK_DEBUG_TOKEN=

# UI gate passwords (client-side convenience only, shipped in the bundle —
# not a real security boundary)
VITE_SITE_PASSWORD=
VITE_HISTORY_PASSWORD=

# --- Server (Vercel serverless — real secrets, never exposed to the browser) ---
# Firestore service-account JSON, as a single line. From Firebase console →
# Project settings → Service accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT=

# EmailJS (weekly summary email)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
WEEKLY_RECIPIENT_EMAIL=

# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`
# so only the cron can trigger the weekly email.
CRON_SECRET=
