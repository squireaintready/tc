rules_version = '2';

// The real lock is App Check enforcement (toggled in the Firebase console):
// it makes Firestore reject any request that didn't come from the real TC web
// app or the Admin SDK. These rules are a second layer — only the three known
// collections are reachable and everything else is denied. The app has no user
// login, so access within these collections is open to App-Check-verified
// clients by design.
service cloud.firestore {
  match /databases/{database}/documents {
    match /staff/{doc} {
      allow read, write: if true;
    }
    match /history/{doc} {
      allow read, write: if true;
    }
    match /settings/{doc} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
